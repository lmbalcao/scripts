#!/usr/bin/env bash
# git-options — menu simples para gerir repositórios (Forgejo/GitHub)
set -euo pipefail

# =========================
# CONFIG
# =========================
TEMPLATE_DIR="${TEMPLATE_DIR:-$HOME/workspace/repos/templates/repository}"

# Ficheiros “base” + automação (workflow + changelog)
REQUIRED_FILES=(
  ".gitattributes"
  ".gitignore"
  ".prettierrc"
  "README.md"
  "VERSION"
  "CHANGELOG.md"
  ".forgejo/workflows/release.yml"
)

# Defaults de Forgejo (sem tea)
FORGEJO_BASE_URL="${FORGEJO_BASE_URL:-https://forgejo.lbtec.org}"
FORGEJO_OWNER="${FORGEJO_OWNER:-lmbalcao}"
FORGEJO_PROTO="${FORGEJO_PROTO:-https}"   # https | ssh

# =========================
# HELPERS
# =========================
die()  { echo "[ERRO] $*" >&2; exit 1; }
warn() { echo "[AVISO] $*" >&2; }
info() { echo "[OK] $*"; }

require_cmd() { command -v "$1" >/dev/null 2>&1 || die "Falta comando: $1"; }
is_git_repo() { git rev-parse --is-inside-work-tree >/dev/null 2>&1; }

repo_root() { git rev-parse --show-toplevel 2>/dev/null || pwd -P; }
current_dir_name() { basename "$(repo_root)"; }

read_version_file() {
  local f v p s
  f="$(repo_root)/VERSION"
  if [[ ! -f "$f" ]]; then
    echo "1.0.0"; echo "private"; echo "active"; return 0
  fi
  v="$(sed -n '1p' "$f" | tr -d '\r' | xargs || true)"
  p="$(sed -n '2p' "$f" | tr -d '\r' | xargs || true)"
  s="$(sed -n '3p' "$f" | tr -d '\r' | xargs || true)"
  [[ -n "${v:-}" ]] || v="1.0.0"
  [[ -n "${p:-}" ]] || p="private"
  [[ -n "${s:-}" ]] || s="active"
  echo "$v"; echo "$p"; echo "$s"
}

write_version_file() {
  local v="$1" p="$2" s="$3"
  printf "%s\n%s\n%s\n" "$v" "$p" "$s" > "$(repo_root)/VERSION"
}

git_commit_if_needed() {
  local msg="$1"
  is_git_repo || die "Não é repo git (ainda). Usa a opção 1."
  if git diff --quiet && git diff --cached --quiet; then
    warn "Sem alterações para commit."
    return 0
  fi
  git add -A
  git commit -m "$msg"
}

git_push_if_possible() {
  is_git_repo || die "Não é repo git."
  if git remote get-url origin >/dev/null 2>&1; then
    git push -u origin HEAD
    info "Push concluído."
  else
    warn "Sem remoto 'origin'. Configura via opção 1."
  fi
}

ensure_required_files() {
  local root missing f parent
  root="$(repo_root)"
  [[ -d "$TEMPLATE_DIR" ]] || die "Template não existe: $TEMPLATE_DIR"

  missing=0
  for f in "${REQUIRED_FILES[@]}"; do
    if [[ ! -f "$root/$f" ]]; then
      warn "Falta: $f"
      missing=1
    fi
  done

  if [[ "$missing" -eq 0 ]]; then
    info "Ficheiros obrigatórios já existem."
    return 0
  fi

  for f in "${REQUIRED_FILES[@]}"; do
    if [[ ! -f "$root/$f" ]]; then
      [[ -f "$TEMPLATE_DIR/$f" ]] || die "Template não tem $f em $TEMPLATE_DIR"
      parent="$(dirname "$root/$f")"
      mkdir -p "$parent"
      cp -n "$TEMPLATE_DIR/$f" "$root/$f"
      info "Copiado (sem substituir): $f"
    fi
  done

  # Normalizar VERSION para 3 linhas (caso venha incompleto)
  local v p s
  readarray -t _ver < <(read_version_file)
  v="${_ver[0]}"; p="${_ver[1]}"; s="${_ver[2]}"
  write_version_file "$v" "$p" "$s"
  info "VERSION normalizado: $v / $p / $s"
}

select_from_two() {
  local prompt="$1" a="$2" b="$3" current="$4"
  echo "$prompt (atual: $current)"
  echo "  1) $a"
  echo "  2) $b"
  read -r -p "Escolhe [1-2] (Enter = manter): " choice
  case "${choice:-}" in
    1) echo "$a" ;;
    2) echo "$b" ;;
    "") echo "$current" ;;
    *) die "Opção inválida." ;;
  esac
}

# =========================
# ACTIONS
# =========================
action_1_init_git_and_remote() {
  require_cmd git
  local root name url method
  root="$(repo_root)"
  cd "$root"

  ensure_required_files

  if is_git_repo; then
    warn "Já é um repositório git."
  else
    git init -b main
    info "git init feito."
  fi

  if ! git rev-parse HEAD >/dev/null 2>&1; then
    git add -A
    git commit -m "Initial commit"
    info "Commit inicial criado."
  fi

  echo
  echo "Criar/configurar remoto:"
  echo "  1) GitHub via gh (cria repo remoto + push)"
  echo "  2) Forgejo (sem tea) — só configura origin + push (repo remoto tem de existir)"
  echo "  3) Manual (introduzir URL do remoto)"
  read -r -p "Escolhe [1-3]: " method

  name="$(current_dir_name)"

  case "$method" in
    1)
      require_cmd gh
      # privacidade do VERSION (2ª linha)
      local v p s flag
      readarray -t _ver < <(read_version_file)
      v="${_ver[0]}"; p="${_ver[1]}"; s="${_ver[2]}"
      flag="--public"; [[ "$p" == "private" ]] && flag="--private"
      gh repo create "$name" "$flag" --source="." --remote=origin --push
      info "Repo GitHub criado e push feito."
      ;;
    2)
      local forgejo_base owner proto host
      forgejo_base="${FORGEJO_BASE_URL%/}"
      owner="${FORGEJO_OWNER}"
      proto="${FORGEJO_PROTO}"

      if [[ "$proto" == "ssh" ]]; then
        host="$(echo "$forgejo_base" | sed -E 's#^https?://##; s#/.*##')"
        url="git@${host}:${owner}/${name}.git"
      else
        url="${forgejo_base}/${owner}/${name}.git"
      fi

      echo "Remote Forgejo calculado: $url"
      read -r -p "Confirmar configurar origin para este URL? [s/N]: " ok
      case "${ok:-}" in s|S|sim|SIM) ;; *) info "Cancelado."; return 0 ;; esac

      if git remote get-url origin >/dev/null 2>&1; then
        git remote set-url origin "$url"
      else
        git remote add origin "$url"
      fi
      git push -u origin HEAD
      info "Origin configurado e push executado."
      ;;
    3)
      read -r -p "URL do remoto (https/ssh): " url
      [[ -n "$url" ]] || die "URL vazio."
      if git remote get-url origin >/dev/null 2>&1; then
        git remote set-url origin "$url"
      else
        git remote add origin "$url"
      fi
      git push -u origin HEAD
      info "Remoto configurado e push feito."
      ;;
    *)
      die "Opção inválida."
      ;;
  esac
}

action_2_toggle_privacy() {
  require_cmd git
  ensure_required_files
  local v p s new_p
  readarray -t _ver < <(read_version_file)
  v="${_ver[0]}"; p="${_ver[1]}"; s="${_ver[2]}"

  if [[ "$p" == "private" ]]; then new_p="public"; else new_p="private"; fi
  write_version_file "$v" "$new_p" "$s"
  info "Privacidade alterada: $p -> $new_p"

  if is_git_repo; then
    git_commit_if_needed "Change privacy to ${new_p}"
    git_push_if_possible
  else
    warn "Não é repo git. Usa a opção 1 para inicializar."
  fi
}

action_3_toggle_state() {
  require_cmd git
  ensure_required_files
  local v p s new_s
  readarray -t _ver < <(read_version_file)
  v="${_ver[0]}"; p="${_ver[1]}"; s="${_ver[2]}"

  if [[ "$s" == "active" ]]; then new_s="archived"; else new_s="active"; fi
  write_version_file "$v" "$p" "$new_s"
  info "Estado alterado: $s -> $new_s"

  if is_git_repo; then
    git_commit_if_needed "Change state to ${new_s}"
    git_push_if_possible
  else
    warn "Não é repo git. Usa a opção 1 para inicializar."
  fi
}

action_5_ensure_files() {
  require_cmd git
  ensure_required_files
  if is_git_repo; then
    git_commit_if_needed "Ensure standard repository files"
    git_push_if_possible
  else
    warn "Não é repo git. Ficheiros garantidos localmente; usa a opção 1 para init/push."
  fi
}

show_status() {
  local v p s
  readarray -t _ver < <(read_version_file)
  v="${_ver[0]}"; p="${_ver[1]}"; s="${_ver[2]}"

  echo
  echo "Repo: $(repo_root)"
  echo "VERSION:"
  echo "  versão:      $v"
  echo "  privacidade: $p"
  echo "  estado:      $s"
  echo "Git: $(if is_git_repo; then echo "sim"; else echo "não"; fi)"
  if is_git_repo && git remote get-url origin >/dev/null 2>&1; then
    echo "Origin: $(git remote get-url origin)"
  else
    echo "Origin: (nenhum)"
  fi
  echo
}

main_menu() {
  while true; do
    show_status
    echo "Menu:"
    echo "  1) Gera Git (init + criar repo remoto + push)"
    echo "  2) Altera Privacidade (private/public) + commit + push"
    echo "  3) Altera Estado (active/archived) + commit + push"
    echo "  5) Garante Ficheiros (copiar do template se faltar) + commit + push"
    echo "  0) Sair"
    read -r -p "Escolhe [0-5]: " opt
    case "${opt:-}" in
      1) action_1_init_git_and_remote ;;
      2) action_2_toggle_privacy ;;
      3) action_3_toggle_state ;;
      5) action_5_ensure_files ;;
      0) exit 0 ;;
      *) warn "Opção inválida." ;;
    esac
  done
}

main_menu
